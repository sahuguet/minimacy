// Minimacy Agentic Loop — agent.mcy
// Interactive shell backed by Claude API with native tool dispatch.
//
// Usage:
//   minimacyMac agent.mcy --key <API_KEY> [--model <MODEL>] [--tokens <N>]
//
// Available tools: read_file, write_file, list_files, http_fetch, get_time
// Shell commands:  /exit

use core.util.json;;
use core.net.http.cli;;

const ANTHROPIC_URL     = "https://api.anthropic.com/v1/messages";;
const ANTHROPIC_VERSION = "2023-06-01";;
const DEFAULT_MODEL     = "claude-opus-4-6";;
const DEFAULT_MAX_TOKENS = 4096;;
const MAX_TOOL_DEPTH    = 10;;

const SYSTEM_PROMPT =
    "You are a helpful AI assistant running inside the Minimacy bare-metal environment. \
You have access to tools for reading/writing files, making HTTP requests, and checking the time. \
Use tools whenever they help you answer accurately.";;

//---------- argument parsing ----------

// Returns [apiKey, model, maxTokens]
fun parseArgs(l, key, model, maxTokens)=
    if l==nil then [key, model, maxTokens]
    else let head(l)->a in let tail(l)->rest in
    if a=="--key"    && rest<>nil then parseArgs(tail(rest), head(rest), model, maxTokens)
    else if a=="--model"  && rest<>nil then parseArgs(tail(rest), key, head(rest), maxTokens)
    else if a=="--tokens" && rest<>nil then parseArgs(tail(rest), key, model, intFromDec(head(rest)))
    else parseArgs(rest, key, model, maxTokens);;

//---------- tool schema builders ----------

fun jsonStrProp(name, desc)=
    [name, jsonObject(
        ["type",        jsonString "string"]::
        ["description", jsonString desc]::
        nil
    )];;

fun jsonInputSchema(props, required)=
    jsonObject(
        ["type",       jsonString "object"]::
        ["properties", jsonObject props]::
        (if required<>nil then
            ["required", jsonList(listMap(required, lambda(s)= jsonString s))]::nil
        else nil)
    );;

fun toolDef(name, desc, props, required)=
    jsonObject(
        ["name",         jsonString name]::
        ["description",  jsonString desc]::
        ["input_schema", jsonInputSchema(props, required)]::
        nil
    );;

fun buildTools()=
    jsonList(
        toolDef("read_file",
            "Read the full contents of a file from disk.",
            jsonStrProp("path", "Absolute or relative file path to read.")::nil,
            "path"::nil
        )::
        toolDef("write_file",
            "Write (overwrite) content to a file on disk.",
            jsonStrProp("path",    "File path to write to.")::
            jsonStrProp("content", "Text content to write.")::nil,
            "path"::"content"::nil
        )::
        toolDef("list_files",
            "List the files in a directory.",
            jsonStrProp("path", "Directory path to list.")::nil,
            "path"::nil
        )::
        toolDef("http_fetch",
            "Make an HTTP GET request and return the response body.",
            jsonStrProp("url", "Full URL to fetch.")::nil,
            "url"::nil
        )::
        toolDef("get_time",
            "Return the current UTC date and time.",
            nil, nil
        )::
        nil
    );;

//---------- tool dispatcher ----------

fun dispatchTool(name, inputJson)=
    if name=="read_file" then
        let jsonStringGet(jsonFieldGet(inputJson, "path"))->path in
        if path==nil then "[read_file] missing 'path' argument"
        else
        let load(path)->data in
        if data<>nil then data
        else strBuild({"[read_file] file not found: ", path})
    else if name=="write_file" then
        let jsonStringGet(jsonFieldGet(inputJson, "path"))->path in
        let jsonStringGet(jsonFieldGet(inputJson, "content"))->content in
        if path==nil || content==nil then "[write_file] missing arguments"
        else
        (save(content, path); strBuild({"[write_file] written: ", path}))
    else if name=="list_files" then
        let jsonStringGet(jsonFieldGet(inputJson, "path"))->path in
        if path==nil then "[list_files] missing 'path' argument"
        else
        let fileList(path)->files in
        if files==nil then "(no files found)"
        else strJoin("\n", files)
    else if name=="http_fetch" then
        let jsonStringGet(jsonFieldGet(inputJson, "url"))->url in
        if url==nil then "[http_fetch] missing 'url' argument"
        else
        let try (
            let httpCreate("GET", url, "HTTP/1.0")->h in
            let await(lambda(join)=
                httpSend(h, lambda(code, data)= joinSend(join, [code, data]))
            )->[code, data] in
            if code==nil then "[http_fetch] connection failed"
            else if code<>200 then strBuild({"[http_fetch] HTTP ", decFromInt(code)})
            else if data==nil then "" else data
        )->r in
        if r<>nil then r else "[http_fetch] request failed"
    else if name=="get_time" then
        fullDate(time())
    else
        strBuild({"[agent] unknown tool: ", name});;

//---------- JSON message helpers ----------

// msg: [role, jsonContent]
// content is jsonString for plain text, jsonArray for tool use / tool results
fun msgToJson(msg)=
    let msg->[role, content] in
    jsonObject(
        ["role",    jsonString role]::
        ["content", content]::
        nil
    );;

fun buildBody(messages, model, maxTokens)=
    jsonEncode(jsonObject(
        ["model",      jsonString model]::
        ["max_tokens", jsonInt(maxTokens)]::
        ["system",     jsonString SYSTEM_PROMPT]::
        ["tools",      buildTools()]::
        ["messages",   jsonList(listMap(messages, #msgToJson))]::
        nil
    ));;

//---------- response parsing ----------

// Walk the content array; accumulate text and tool_use calls.
// Returns [textStr, toolCallsList]
// toolCallsList: list of [id, name, inputJson]
fun _parseBlocks(arr, i, text, tools)=
    if i >= arrayLength(arr) then [text, tools]
    else
    let arr[i]->block in
    let jsonStringGet(jsonFieldGet(block, "type"))->type in
    if type=="text" then
        let jsonStringGet(jsonFieldGet(block, "text"))->t in
        _parseBlocks(arr, i+1,
            if t<>nil then strConcat(text, t) else text,
            tools)
    else if type=="tool_use" then
        let jsonStringGet(jsonFieldGet(block, "id"))->id in
        let jsonStringGet(jsonFieldGet(block, "name"))->tname in
        let jsonFieldGet(block, "input")->inputJson in
        _parseBlocks(arr, i+1, text,
            if id<>nil && tname<>nil then
                [id, tname, inputJson]::tools
            else tools)
    else
        _parseBlocks(arr, i+1, text, tools);;

// Returns [contentJson, text, toolCalls] or nil on parse error.
// contentJson is kept as-is to store verbatim in the assistant message.
fun parseResponse(body)=
    try
    let jsonParse(body, 0)->[json, _] in
    let jsonFieldGet(json, "content")->contentJson in
    let jsonArrayGet(contentJson)->arr in
    let _parseBlocks(arr, 0, "", nil)->[text, tools] in
    [contentJson, text, listReverse(tools)];;

//---------- HTTP ----------

fun sendRequest(apiKey, model, maxTokens, messages)=
    let httpCreate("POST", ANTHROPIC_URL, "HTTP/1.0")->h in
    (
        httpSetHeader(h, "Content-Type",      "application/json");
        httpSetHeader(h, "x-api-key",         apiKey);
        httpSetHeader(h, "anthropic-version", ANTHROPIC_VERSION);
        httpSetPostData(h, buildBody(messages, model, maxTokens));
        let await(lambda(join)=
            httpSend(h, lambda(code, data)= joinSend(join, [code, data]))
        )->[code, data] in
        if code==nil then (echoLn "[Error: connection failed]"; nil)
        else if code<>200 then (echoLn ["[Error HTTP ", decFromInt(code), "]"]; nil)
        else parseResponse(data)
    );;

//---------- agentic loop ----------

// Build a tool_result content block for the next user message.
fun toolResultBlock(id, result)=
    jsonObject(
        ["type",        jsonString "tool_result"]::
        ["tool_use_id", jsonString id]::
        ["content",     jsonString result]::
        nil
    );;

// Dispatch all pending tool calls; print progress; return result blocks.
fun executeTools(toolCalls)=
    listMap(toolCalls, lambda(tc)=
        let tc->[id, tname, inputJson] in
        (
            echoLn ["  [tool] ", tname];
            let dispatchTool(tname, inputJson)->result in
            toolResultBlock(id, result)
        )
    );;

// Send messages to Claude; handle tool calls recursively.
// history: newest-first list of [role, jsonContent]
// Returns [finalText, updatedHistory] or nil on error.
fun agentStep(apiKey, model, maxTokens, history, depth)=
    if depth > MAX_TOOL_DEPTH then
        (echoLn "[agent] max tool iterations reached"; nil)
    else
    let sendRequest(apiKey, model, maxTokens, listReverse(history))->response in
    if response==nil then nil
    else
    let response->[contentJson, text, toolCalls] in
    if toolCalls==nil then
        // Final text answer — store assistant message and return.
        let ["assistant", contentJson]::history->history in
        [text, history]
    else
    (
        // Show any thinking text the model wrote before the tool calls.
        if !strEmpty(text) then echoLn ["  ", text];
        // Add assistant message (which contains the tool_use blocks).
        let ["assistant", contentJson]::history->history in
        // Execute each tool and collect result blocks.
        let executeTools(toolCalls)->resultBlocks in
        // Append tool results as a single user message and recurse.
        let ["user", jsonList(resultBlocks)]::history->history in
        agentStep(apiKey, model, maxTokens, history, depth+1)
    );;

//---------- interactive shell ----------

fun shellLoop(apiKey, model, maxTokens, history)=
    onPrompt("> ", lambda(input)=
        if input<>nil then
        if input=="/exit" then
            (echoLn "Bye."; silentPrompt(); 0)
        else
        (
            let ["user", jsonString input]::history->newHistory in
            let agentStep(apiKey, model, maxTokens, newHistory, 0)->result in
            (
                if result<>nil then
                let result->[reply, updatedHistory] in
                (
                    if !strEmpty(reply) then echoLn ["Claude: ", reply];
                    shellLoop(apiKey, model, maxTokens, updatedHistory)
                )
                else
                    shellLoop(apiKey, model, maxTokens, history);
                0
            )
        )
    );;

//---------- entry point ----------

fun main()=
    let parseArgs(args(), nil, DEFAULT_MODEL, DEFAULT_MAX_TOKENS)->[apiKey, model, maxTokens] in
    if apiKey==nil then
    (
        echoLn "Usage: minimacyMac agent.mcy --key <KEY> [--model <MODEL>] [--tokens <N>]";
        echoLn ["  Default model  : ", DEFAULT_MODEL];
        echoLn ["  Default tokens : ", decFromInt(DEFAULT_MAX_TOKENS)];
        0
    )
    else
    (
        echoLn ["Minimacy Agent | model: ", model, " | max_tokens: ", decFromInt(maxTokens)];
        echoLn "Tools: read_file  write_file  list_files  http_fetch  get_time";
        echoLn "Type /exit to quit.";
        echoLn "";
        shellLoop(apiKey, model, maxTokens, nil);
        0
    );;
